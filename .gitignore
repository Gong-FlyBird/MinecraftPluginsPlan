# ── 依赖 ──
node_modules

# ── 构建产物 ──
dist
dist-ssr
*.local

# ── 日志 ──
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── 编辑器 ──
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ── 环境变量（防止泄漏 token/密钥） ──
.env
.env.local
.env.*.local

# ── 数据导出（你手动导出的 JSON 放到这个目录会安全） ──
/exports/
/data/
*.backup.json
